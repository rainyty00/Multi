# ============================================================
# 密钥模板文件
# 用法：把本文件复制一份改名为  .env  ，然后填入你真实的 key
# 命令： cp .env.example .env
# ★注意：.env 里是真实密钥，绝对不要提交到 git、不要发给别人
# ============================================================

# 【视觉理解】OpenAI gpt-4o-mini
# 申请地址：https://platform.openai.com/api-keys  （key 形如 sk-...）
# ★需要能访问 OpenAI 的网络（走代理）
OPENAI_API_KEY=你的key填这里
OPENAI_BASE_URL=https://api.openai.com/v1

# 【评估】通义千问 Qwen-VL-Max，走阿里云 DashScope 的 OpenAI 兼容接口
# 申请地址：https://dashscope.console.aliyun.com/   （key 形如 sk-...）
DASHSCOPE_API_KEY=你的key填这里
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 【分镜合成 / 报告】DeepSeek-V3
# 申请地址：https://platform.deepseek.com/   （key 形如 sk-...）
DEEPSEEK_API_KEY=你的key填这里
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
